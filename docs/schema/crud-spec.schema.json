{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/mzivkovicdev/spring-crud-generator/main/docs/schema/crud-spec.schema.json",
  "title": "Spring CRUD Generator Specification",
  "description": "Schema for Spring CRUD Generator YAML/JSON specification files.",
  "type": "object",
  "required": [
    "configuration",
    "entities"
  ],
  "additionalProperties": false,
  "properties": {
    "configuration": {
      "$ref": "#/$defs/configuration"
    },
    "packages": {
      "$ref": "#/$defs/packages"
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entity"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "configuration": {
            "properties": {
              "database": {
                "not": {
                  "enum": [
                    "MONGODB",
                    "mongodb"
                  ]
                }
              }
            },
            "required": [
              "database"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "entities": {
            "items": {
              "properties": {
                "fields": {
                  "items": {
                    "properties": {
                      "id": {
                        "$ref": "#/$defs/idDefinition"
                      },
                      "relation": {
                        "allOf": [
                          {
                            "if": {
                              "properties": {
                                "type": {
                                  "const": "ManyToMany"
                                }
                              },
                              "required": [
                                "type"
                              ]
                            },
                            "then": {
                              "required": [
                                "joinTable"
                              ]
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "configuration": {
            "properties": {
              "database": {
                "enum": [
                  "MONGODB",
                  "mongodb"
                ]
              }
            },
            "required": [
              "database"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "entities": {
            "items": {
              "properties": {
                "fields": {
                  "items": {
                    "properties": {
                      "id": {
                        "$ref": "#/$defs/idBoolean"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "configuration": {
      "type": "object",
      "description": "Global generator configuration.",
      "required": [
        "database"
      ],
      "additionalProperties": false,
      "properties": {
        "database": {
          "type": "string",
          "description": "Database engine. Value matching is case-insensitive in the generator.",
          "enum": [
            "MYSQL",
            "MARIADB",
            "POSTGRESQL",
            "MSSQL",
            "MONGODB",
            "mysql",
            "mariadb",
            "postgresql",
            "mssql",
            "mongodb"
          ]
        },
        "javaVersion": {
          "type": "integer",
          "minimum": 17,
          "maximum": 25,
          "description": "Supported range is 17-25. If omitted, generator defaults to 17."
        },
        "springBootVersion": {
          "type": "string",
          "description": "Optional explicit Spring Boot version (examples: 4, 4.0, 4.0.1).",
          "pattern": "^\\d+(\\.\\d+){0,2}$"
        },
        "optimisticLocking": {
          "type": "boolean"
        },
        "docker": {
          "$ref": "#/$defs/docker"
        },
        "cache": {
          "$ref": "#/$defs/cache"
        },
        "openApi": {
          "$ref": "#/$defs/openApi"
        },
        "graphql": {
          "$ref": "#/$defs/graphql"
        },
        "errorResponse": {
          "type": "string",
          "description": "Error response style. Value matching is case-insensitive in the generator.",
          "enum": [
            "DETAILED",
            "SIMPLE",
            "MINIMAL",
            "NONE",
            "detailed",
            "simple",
            "minimal",
            "none"
          ]
        },
        "migrationScripts": {
          "type": "boolean"
        },
        "dependencyCheck": {
          "type": "boolean",
          "description": "When true, generator scans project pom.xml and warns about missing dependencies required by enabled features."
        },
        "tests": {
          "$ref": "#/$defs/tests"
        },
        "security": {
          "$ref": "#/$defs/security"
        },
        "ai": {
          "$ref": "#/$defs/ai"
        },
        "additionalProperties": {
          "$ref": "#/$defs/additionalProperties"
        }
      }
    },
    "docker": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dockerfile": {
          "type": "boolean"
        },
        "dockerCompose": {
          "type": "boolean"
        },
        "app": {
          "$ref": "#/$defs/dockerApp"
        },
        "db": {
          "$ref": "#/$defs/dockerDb"
        }
      }
    },
    "dockerApp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "dockerDb": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "cache": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "description": "Cache type. Value matching is case-insensitive in the generator.",
          "enum": [
            "REDIS",
            "CAFFEINE",
            "SIMPLE",
            "HAZELCAST",
            "redis",
            "caffeine",
            "simple",
            "hazelcast"
          ]
        },
        "maxSize": {
          "type": "integer",
          "minimum": 1,
          "description": "Used only for CAFFEINE cache."
        },
        "expiration": {
          "type": "integer",
          "minimum": 1,
          "description": "Cache expiration in minutes."
        }
      }
    },
    "openApi": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "apiSpec": {
          "type": "boolean"
        },
        "generateResources": {
          "type": "boolean"
        }
      }
    },
    "graphql": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "scalarConfig": {
          "type": "boolean"
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "unit": {
          "type": "boolean"
        },
        "integration": {
          "type": "boolean"
        },
        "dataGenerator": {
          "type": "string",
          "description": "Used when tests.unit=true. Value matching is case-insensitive in the generator.",
          "enum": [
            "PODAM",
            "INSTANCIO",
            "podam",
            "instancio"
          ]
        }
      }
    },
    "security": {
      "type": "object",
      "description": "Security configuration for generated application endpoints.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enables generation of security-related classes and endpoint protection."
        },
        "type": {
          "type": "string",
          "description": "Security mode. Value matching is case-insensitive in the generator.",
          "enum": [
            "BASIC_AUTH",
            "JWT",
            "OAUTH2_RESOURCE_SERVER",
            "API_KEY",
            "basic_auth",
            "jwt",
            "oauth2_resource_server",
            "api_key"
          ]
        },
        "basicAuth": {
          "$ref": "#/$defs/securityBasicAuth"
        },
        "jwt": {
          "$ref": "#/$defs/securityJwt"
        },
        "oauth2": {
          "$ref": "#/$defs/securityOauth2"
        },
        "apiKey": {
          "$ref": "#/$defs/securityApiKey"
        }
      }
    },
    "securityBasicAuth": {
      "type": "object",
      "description": "Basic authentication configuration.",
      "additionalProperties": false,
      "properties": {
        "users": {
          "type": "array",
          "description": "In-memory users used for generated basic authentication setup.",
          "items": {
            "$ref": "#/$defs/securityBasicAuthUser"
          },
          "minItems": 1
        }
      }
    },
    "securityBasicAuthUser": {
      "type": "object",
      "description": "Single Basic Auth user entry.",
      "additionalProperties": false,
      "properties": {
        "username": {
          "type": "string",
          "description": "Username used for authentication."
        },
        "password": {
          "type": "string",
          "description": "Raw password that will be encoded in generated setup."
        },
        "roles": {
          "type": "array",
          "description": "Granted roles for this user.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "securityJwt": {
      "type": "object",
      "description": "JWT token settings used in generated token provider.",
      "additionalProperties": false,
      "properties": {
        "secret": {
          "type": "string",
          "description": "Signing secret used to issue and validate JWT tokens."
        },
        "expirationMs": {
          "type": "integer",
          "minimum": 1,
          "description": "Token expiration time in milliseconds."
        },
        "issuer": {
          "type": "string",
          "description": "JWT issuer claim value."
        }
      }
    },
    "securityOauth2": {
      "type": "object",
      "description": "OAuth2 resource server settings.",
      "additionalProperties": false,
      "properties": {
        "issuerUri": {
          "type": "string",
          "description": "Issuer URI used by Spring Security resource server."
        },
        "jwkSetUri": {
          "type": "string",
          "description": "JWK Set URI used to fetch signing keys."
        },
        "rolesClaim": {
          "type": "string",
          "description": "Claim path used to resolve roles from JWT payload (for example realm_access.roles)."
        }
      }
    },
    "securityApiKey": {
      "type": "object",
      "description": "API key security settings.",
      "additionalProperties": false,
      "properties": {
        "headerName": {
          "type": "string",
          "description": "HTTP header name expected to carry the API key."
        },
        "keys": {
          "type": "array",
          "description": "Allowed API key entries.",
          "items": {
            "$ref": "#/$defs/securityApiKeyEntry"
          },
          "minItems": 1
        }
      }
    },
    "securityApiKeyEntry": {
      "type": "object",
      "description": "Single API key definition with assigned roles.",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Logical key name used for identification."
        },
        "value": {
          "type": "string",
          "description": "Secret API key value accepted by generated filter."
        },
        "roles": {
          "type": "array",
          "description": "Roles granted when this API key is presented.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "ai": {
      "type": "object",
      "description": "AI context artifact generation settings.",
      "additionalProperties": false,
      "properties": {
        "claude": {
          "type": "boolean",
          "description": "When true, generates CLAUDE.md context file."
        },
        "agents": {
          "type": "boolean",
          "description": "When true, generates AGENTS.md context file."
        }
      }
    },
    "additionalProperties": {
      "type": "object",
      "description": "Additional feature flags and tuning options. Unknown keys are allowed.",
      "properties": {
        "rest.basePath": {
          "type": "string",
          "description": "Base path prefix for generated REST controllers (example: /api/v1)."
        },
        "rest.basepath": {
          "type": "string",
          "description": "Deprecated alias for rest.basePath."
        },
        "rest.response.excludeNull": {
          "type": "boolean"
        },
        "optimisticLocking.retry.config": {
          "type": "boolean"
        },
        "optimisticLocking.retry.maxAttempts": {
          "type": "integer",
          "minimum": 1
        },
        "optimisticLocking.backoff.delayMs": {
          "type": "integer",
          "minimum": 0
        },
        "optimisticLocking.backoff.maxDelayMs": {
          "type": "integer",
          "minimum": 0
        },
        "optimisticLocking.backoff.multiplier": {
          "type": "number",
          "minimum": 0
        },
        "spring.jpa.open-in-view": {
          "type": "boolean"
        },
        "github.actions": {
          "type": "boolean",
          "description": "Generate a basic GitHub Actions CI workflow under .github/workflows/ci.yml."
        }
      },
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      }
    },
    "packages": {
      "type": "object",
      "description": "Optional package customization.",
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "$ref": "#/$defs/packagePath"
        },
        "businessservices": {
          "$ref": "#/$defs/packagePath"
        },
        "configurations": {
          "$ref": "#/$defs/packagePath"
        },
        "controllers": {
          "$ref": "#/$defs/packagePath"
        },
        "enums": {
          "$ref": "#/$defs/packagePath"
        },
        "exceptions": {
          "$ref": "#/$defs/packagePath"
        },
        "generated": {
          "$ref": "#/$defs/packagePath"
        },
        "mappers": {
          "$ref": "#/$defs/packagePath"
        },
        "models": {
          "$ref": "#/$defs/packagePath"
        },
        "resolvers": {
          "$ref": "#/$defs/packagePath"
        },
        "repositories": {
          "$ref": "#/$defs/packagePath"
        },
        "services": {
          "$ref": "#/$defs/packagePath"
        },
        "transferobjects": {
          "$ref": "#/$defs/packagePath"
        }
      }
    },
    "packagePath": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_.]*$"
    },
    "entity": {
      "type": "object",
      "required": [
        "name",
        "fields"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Model class name (for example ProductModel)."
        },
        "storageName": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Database table name in lower_snake_case. Optional for models used only as JSON inner objects."
        },
        "description": {
          "type": "string"
        },
        "ignore": {
          "type": "boolean"
        },
        "softDelete": {
          "type": "boolean"
        },
        "audit": {
          "$ref": "#/$defs/audit"
        },
        "bulk": {
          "$ref": "#/$defs/bulk"
        },
        "sort": {
          "$ref": "#/$defs/sort",
          "description": "Optional entity-level sorting configuration for REST list endpoints and GraphQL list queries."
        },
        "security": {
          "$ref": "#/$defs/entitySecurity",
          "description": "Optional entity-level role mapping for CRUD and relation operations."
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/field"
          }
        }
      }
    },
    "entitySecurity": {
      "type": "object",
      "description": "Per-entity operation security mapping. If omitted, operation defaults to authenticated access when global security is enabled.",
      "additionalProperties": false,
      "properties": {
        "getAll": {
          "type": "array",
          "description": "Allowed roles for list/getAll operation.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "getById": {
          "type": "array",
          "description": "Allowed roles for get-by-id operation.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "create": {
          "type": "array",
          "description": "Allowed roles for create operation.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "update": {
          "type": "array",
          "description": "Allowed roles for update operation.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "delete": {
          "type": "array",
          "description": "Allowed roles for delete operation.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "addRelation": {
          "type": "array",
          "description": "Allowed roles for add-relation operation.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "removeRelation": {
          "type": "array",
          "description": "Allowed roles for remove-relation operation.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": [
            "INSTANT",
            "LOCALDATE",
            "LOCALDATETIME",
            "instant",
            "localdate",
            "localdatetime"
          ]
        }
      }
    },
    "bulk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "$ref": "#/$defs/bulkCreate"
        }
      }
    },
    "bulkCreate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "sortDirection": {
      "type": "string",
      "description": "Sort direction used when sortBy is provided and request does not provide direction.",
      "enum": [
        "ASC",
        "DESC",
        "asc",
        "desc"
      ]
    },
    "sort": {
      "type": "object",
      "description": "Defines sortable fields and default sorting behavior for one entity.",
      "additionalProperties": false,
      "required": [
        "allowedFields"
      ],
      "properties": {
        "allowedFields": {
          "type": "array",
          "description": "List of entity fields that can be used in sortBy.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "defaultDirection": {
          "$ref": "#/$defs/sortDirection",
          "description": "Default direction used when sortBy is present but sortDirection is not provided."
        }
      }
    },
    "field": {
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "$ref": "#/$defs/fieldType"
        },
        "description": {
          "type": "string"
        },
        "example": {
          "type": "string",
          "description": "Example value used in generated OpenAPI schema."
        },
        "id": {
          "$ref": "#/$defs/id"
        },
        "values": {
          "type": "array",
          "description": "Required when type is Enum.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "relation": {
          "$ref": "#/$defs/relation"
        },
        "column": {
          "$ref": "#/$defs/column"
        },
        "validation": {
          "$ref": "#/$defs/validation"
        }
      }
    },
    "fieldType": {
      "type": "string",
      "description": "Supported: basic Java type, Enum, JSON<...>, List<basicType>, Set<basicType>, or another model name.",
      "examples": [
        "String",
        "Long",
        "Character",
        "Integer",
        "Boolean",
        "Double",
        "Float",
        "Short",
        "Byte",
        "UUID",
        "BigDecimal",
        "BigInteger",
        "LocalDate",
        "LocalDateTime",
        "OffsetDateTime",
        "Instant",
        "Enum",
        "List<String>",
        "Set<String>",
        "JSON<Long>",
        "JSON<String>",
        "CustomerModel",
        "Customer"
      ]
    },
    "id": {
      "description": "ID declaration. Use id: true as a lightweight marker (MongoDB/NoSQL), or use object form with strategy for SQL/JPA.",
      "oneOf": [
        {
          "$ref": "#/$defs/idBoolean"
        },
        {
          "$ref": "#/$defs/idDefinition"
        }
      ]
    },
    "idBoolean": {
      "type": "boolean"
    },
    "idDefinition": {
      "type": "object",
      "required": [
        "strategy"
      ],
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "description": "ID generation strategy. Value matching is case-insensitive in the generator.",
          "enum": [
            "TABLE",
            "SEQUENCE",
            "UUID",
            "IDENTITY",
            "AUTO"
          ]
        },
        "generatorName": {
          "type": "string"
        },
        "allocationSize": {
          "type": "integer",
          "minimum": 1
        },
        "initialValue": {
          "type": "integer",
          "minimum": 1
        },
        "pkColumnName": {
          "type": "string"
        },
        "valueColumnName": {
          "type": "string"
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "OneToOne",
            "OneToMany",
            "ManyToOne",
            "ManyToMany"
          ]
        },
        "joinColumn": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "fetch": {
          "type": "string",
          "enum": [
            "EAGER",
            "LAZY"
          ]
        },
        "cascade": {
          "type": "string",
          "description": "JPA cascade type (for example: ALL, PERSIST, MERGE, REMOVE, REFRESH, DETACH)."
        },
        "orphanRemoval": {
          "type": "boolean"
        },
        "uniqueItems": {
          "type": "boolean",
          "description": "Supported for OneToMany and ManyToMany only."
        },
        "joinTable": {
          "$ref": "#/$defs/joinTable"
        }
      }
    },
    "joinTable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "joinColumn",
        "inverseJoinColumn"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "joinColumn": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "inverseJoinColumn": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "unique": {
          "type": "boolean"
        },
        "nullable": {
          "type": "boolean"
        },
        "insertable": {
          "type": "boolean"
        },
        "updateable": {
          "type": "boolean"
        },
        "length": {
          "type": "integer",
          "minimum": 1
        },
        "precision": {
          "type": "integer",
          "minimum": 1
