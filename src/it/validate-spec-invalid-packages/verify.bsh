import java.io.BufferedReader;
import java.io.File;
import java.io.FileReader;

String readFile(String relativePath) throws Exception {
    File file = new File(basedir, relativePath);
    if (!file.isFile()) {
        throw new RuntimeException("Expected file is missing: " + file.getAbsolutePath());
    }

    StringBuilder sb = new StringBuilder();
    BufferedReader reader = new BufferedReader(new FileReader(file));
    try {
        String line;
        while ((line = reader.readLine()) != null) {
            sb.append(line).append('\n');
        }
    } finally {
        reader.close();
    }
    return sb.toString();
}

void requireContains(String relativePath, String expectedText) throws Exception {
    String content = readFile(relativePath);
    if (!content.contains(expectedText)) {
        throw new RuntimeException("Expected text not found in " + relativePath + ": " + expectedText);
    }
}

requireContains("build.log", "Spec validation failed");
requireContains("build.log", "Invalid package configuration. Missing required package(s):");
requireContains("build.log", "resolvers (required when graphQl is enabled)");
